PORT=8888

# DeepSeek API（必填）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱 API（KB embedding + 图片描述，llm role 必填）
ZHIPU_API_KEY=

# 虎皮椒支付（可选，不填则充值功能不可用）
HUPIJIAO_APP_ID=
HUPIJIAO_APP_SECRET=
HUPIJIAO_NOTIFY_URL=https://udiskai.top/api/pay/notify

# 新用户免费额度（tokens），默认 200 万
FREE_CREDITS=2000000

# 数据库路径（默认同目录）
# DB_PATH=/var/data/udiskai-server.sqlite
